
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read and write their own document in the persons collection
    match /persons/{userId} {
      allow read, write: if request.auth.uid == userId;
    }
    // Users can read all other users' basic info for contact selection, but not write
    match /persons/{userId} {
      allow get;
    }

    // A user can only read/write a contact document if they are a participant
    match /contacts/{contactId} {
      allow read, write, delete: if request.auth.uid in resource.data.participants;
      
      // Messages can only be created by participants, and read by participants
      match /messages/{messageId} {
        allow read, create: if request.auth.uid in get(/databases/$(database)/documents/contacts/$(contactId)).data.participants;
      }
    }
  }
}
